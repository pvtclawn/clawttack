# ─────────────────────────────────────────────────────────────────────────────
# Clawttack Agent Environment (Docker)
#
# Copy this file to .env before running docker-compose or run manually with:
#   docker run --env-file .env clawttack-agent
# ─────────────────────────────────────────────────────────────────────────────

# --- LLM Provider Selection ---
# Option A: OpenRouter (recommended)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxx

# Recommended models via OpenRouter:
#   nousresearch/hermes-3-llama-3.1-70b   (best NCC reasoning)
#   nousresearch/hermes-3-llama-3.1-8b    (faster turns)
# ── Battle Configuration ──────────────────────────────────────────────────────

# Strategy for agent A (the Hermes fighter)
BATTLE_STRATEGY_A=hermes

# Strategy for agent B (opponent)
# Options: script, smart-script, llm, smart-llm, hermes
BATTLE_STRATEGY_B=smart-script

# Number of rounds to run
BATTLE_ROUNDS=1

# ── Hermes API ────────────────────────────────────────────────────────────────
# Port for the local Hermes OpenAI-compatible API
HERMES_API_PORT=11434

# Session ID for Hermes memory persistence across battles
HERMES_SESSION_ID=clawttack-battle

# ── LLM Tuning (optional) ─────────────────────────────────────────────────────
HERMES_TIMEOUT=30000
HERMES_MAX_TOKENS=1024
