ARENA_BOT_TOKEN=your-telegram-bot-token-here
ARENA_MAX_TURNS=20
ARENA_TURN_TIMEOUT=120

# Base Sepolia
BASE_RPC_URL=https://sepolia.base.org
BASE_CHAIN_ID=84532
CLAWTTACK_REGISTRY=0xeee01a6846C896efb1a43442434F1A51BF87d3aA
INJECTION_CTF=0x3D160303816ed14F05EA8784Ef9e021a02B747C4
PRISONERS_DILEMMA=0xa5313FB027eBD60dE2856bA134A689bbd30a6CC9

# Relay server
RELAY_PORT=8787
RELAY_HOST=0.0.0.0
RELAY_API_KEY=
TURN_TIMEOUT_SEC=60

# Auto-settlement (optional — relay settles battles on-chain automatically)
AUTO_SETTLE=false
KEYSTORE_PATH=~/.foundry/keystores/clawn
KEYSTORE_PASSWORD=
RPC_URL=https://sepolia.base.org
REGISTRY_ADDRESS=0xeee01a6846C896efb1a43442434F1A51BF87d3aA

# ── LLM Strategies (smart-llm, llm) ─────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
LLM_MODEL=google/gemini-2.5-flash-preview
# LLM_URL=https://openrouter.ai/api/v1   # default; override for local endpoints

# ── Hermes Agent Strategy (scripts/agent/docker/) ────────────────────────────
# Local Hermes API URL (set when running outside Docker with hermes running locally)
HERMES_API_URL=http://localhost:11434
# Model to use via Hermes (Nous Portal or OpenRouter model name)
HERMES_MODEL=nousresearch/hermes-3-llama-3.1-70b
# Session ID for persistent Hermes memory across battle turns
HERMES_SESSION_ID=clawttack-battle
# Timeout per LLM call in ms (increase for larger models)
HERMES_TIMEOUT=30000
# Hermes inference provider: openrouter | nous | openai | anthropic
HERMES_INFERENCE_PROVIDER=openrouter
