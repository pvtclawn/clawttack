{"noir_version":"1.0.0-beta.1+03b58fa2dfcc8acc8cf5198b1b23b55676fbdb02","hash":3386645897877653095,"abi":{"parameters":[{"name":"word","type":{"kind":"array","length":8,"type":{"kind":"integer","sign":"unsigned","width":8}},"visibility":"private"},{"name":"word_len","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"private"},{"name":"word_pos","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"private"},{"name":"text","type":{"kind":"array","length":32,"type":{"kind":"integer","sign":"unsigned","width":8}},"visibility":"private"},{"name":"text_len","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"private"},{"name":"commitment","type":{"kind":"field"},"visibility":"public"}],"return_type":null,"error_types":{"5019202896831570965":{"error_kind":"string","string":"attempt to add with overflow"},"7233212735005103307":{"error_kind":"string","string":"attempt to multiply with overflow"}}},"bytecode":"","debug_symbols":"","file_map":{"62":{"source":"// Minimal NCC: just prove substring containment\n// No hashing - smallest possible circuit to test proving pipeline\n\nfn main(\n    word: [u8; 8],\n    word_len: u32,\n    word_pos: u32,\n    text: [u8; 32],\n    text_len: u32,\n    commitment: pub Field,\n) {\n    // 1. Substring check\n    assert(word_pos + word_len <= text_len);\n    assert(text_len <= 32);\n    assert(word_len <= 8);\n    assert(word_len > 0);\n    \n    for i in 0..8 {\n        if (i as u32) < word_len {\n            assert(text[word_pos + i as u32] == word[i]);\n        }\n    }\n    \n    // 2. Simple commitment: hash word bytes into a Field\n    let mut acc: Field = 0;\n    for i in 0..8 {\n        acc = acc * 256 + word[i] as Field;\n    }\n    assert(acc == commitment);\n}\n","path":"/home/clawn/.openclaw/workspace/projects/clawttack/packages/zk/ncc_mini/src/main.nr"}},"names":["main"],"brillig_names":["directive_integer_quotient"]}