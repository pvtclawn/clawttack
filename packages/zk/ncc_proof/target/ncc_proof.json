{"noir_version":"1.0.0-beta.9+6abff2f16e1c1314ba30708d1cf032a536de3d19","hash":"5108353106082831904","abi":{"parameters":[{"name":"word","type":{"kind":"array","length":16,"type":{"kind":"integer","sign":"unsigned","width":8}},"visibility":"private"},{"name":"word_len","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"private"},{"name":"word_position","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"private"},{"name":"narrative","type":{"kind":"array","length":128,"type":{"kind":"integer","sign":"unsigned","width":8}},"visibility":"private"},{"name":"narrative_len","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"private"},{"name":"context_hash_hi","type":{"kind":"field"},"visibility":"public"},{"name":"context_hash_lo","type":{"kind":"field"},"visibility":"public"},{"name":"narrative_hash_hi","type":{"kind":"field"},"visibility":"public"},{"name":"narrative_hash_lo","type":{"kind":"field"},"visibility":"public"}],"return_type":null,"error_types":{"5019202896831570965":{"error_kind":"string","string":"attempt to add with overflow"}}},"bytecode":"","debug_symbols":"","file_map":{"50":{"source":"// NCC Proof v2: Prove a word exists in narrative text\n// Optimized: 4 public Field inputs instead of 64 byte inputs\n// Each blake2s hash split into hi/lo 128-bit halves (fits Bn254 field)\n\nfn bytes_hi(bytes: [u8; 32]) -> Field {\n    let mut result: Field = 0;\n    for i in 0..16 {\n        result = result * 256 + bytes[i] as Field;\n    }\n    result\n}\n\nfn bytes_lo(bytes: [u8; 32]) -> Field {\n    let mut result: Field = 0;\n    for i in 16..32 {\n        result = result * 256 + bytes[i] as Field;\n    }\n    result\n}\n\nfn main(\n    word: [u8; 16],        // padded word (max 16 bytes)\n    word_len: u32,\n    word_position: u32,\n    narrative: [u8; 128],  // padded narrative (max 128 bytes)\n    narrative_len: u32,\n\n    context_hash_hi: pub Field,   // blake2s(word) upper 128 bits\n    context_hash_lo: pub Field,   // blake2s(word) lower 128 bits\n    narrative_hash_hi: pub Field, // blake2s(narrative) upper 128 bits\n    narrative_hash_lo: pub Field, // blake2s(narrative) lower 128 bits\n) {\n    // 1. Substring check: word appears at word_position in narrative\n    assert(word_len > 0);\n    assert(word_len <= 16);\n    assert(narrative_len <= 128);\n    assert(word_position + word_len <= narrative_len);\n\n    for i in 0..16 {\n        if (i as u32) < word_len {\n            assert(narrative[word_position + i as u32] == word[i]);\n        }\n    }\n\n    // 2. Verify context_hash == blake2s(word)\n    let computed_context = std::hash::blake2s(word);\n    assert(bytes_hi(computed_context) == context_hash_hi);\n    assert(bytes_lo(computed_context) == context_hash_lo);\n\n    // 3. Verify narrative_hash == blake2s(narrative)\n    let computed_narrative = std::hash::blake2s(narrative);\n    assert(bytes_hi(computed_narrative) == narrative_hash_hi);\n    assert(bytes_lo(computed_narrative) == narrative_hash_lo);\n}\n","path":"/home/clawn/.openclaw/workspace/projects/clawttack/packages/zk/ncc_proof/src/main.nr"}},"names":["main"],"brillig_names":["directive_integer_quotient"]}