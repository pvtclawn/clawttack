{"noir_version":"1.0.0-beta.1+03b58fa2dfcc8acc8cf5198b1b23b55676fbdb02","hash":5136151801105839145,"abi":{"parameters":[{"name":"word","type":{"kind":"array","length":16,"type":{"kind":"integer","sign":"unsigned","width":8}},"visibility":"private"},{"name":"word_len","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"private"},{"name":"word_position","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"private"},{"name":"narrative","type":{"kind":"array","length":128,"type":{"kind":"integer","sign":"unsigned","width":8}},"visibility":"private"},{"name":"narrative_len","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"private"},{"name":"context_hash","type":{"kind":"array","length":32,"type":{"kind":"integer","sign":"unsigned","width":8}},"visibility":"public"},{"name":"narrative_hash","type":{"kind":"array","length":32,"type":{"kind":"integer","sign":"unsigned","width":8}},"visibility":"public"}],"return_type":null,"error_types":{"5019202896831570965":{"error_kind":"string","string":"attempt to add with overflow"},"7233212735005103307":{"error_kind":"string","string":"attempt to multiply with overflow"}}},"bytecode":"","debug_symbols":"","file_map":{"62":{"source":"// NCC Proof-of-Concept (minimal): Prove a word exists in text\n// Reduced sizes for quick PoC proving\n\nfn main(\n    word: [u8; 16],        // padded word (max 16 bytes)\n    word_len: u32,\n    word_position: u32,\n    narrative: [u8; 128],  // padded narrative (max 128 bytes)\n    narrative_len: u32,\n\n    context_hash: pub [u8; 32],\n    narrative_hash: pub [u8; 32],\n) {\n    // 1. Substring check\n    assert(word_position + word_len <= narrative_len);\n    for i in 0..16 {\n        if (i as u32) < word_len {\n            assert(narrative[word_position + i as u32] == word[i]);\n        }\n    }\n\n    // 2. context_hash == blake2s(word)\n    let computed_context = std::hash::blake2s(word);\n    assert(computed_context == context_hash);\n\n    // 3. narrative_hash == blake2s(narrative)\n    let computed_narrative = std::hash::blake2s(narrative);\n    assert(computed_narrative == narrative_hash);\n}\n","path":"/home/clawn/.openclaw/workspace/projects/clawttack/packages/zk/ncc_proof/src/main.nr"}},"names":["main"],"brillig_names":["directive_integer_quotient"]}